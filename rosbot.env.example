# Copy this file to rosbot.env and edit it for your robot.

# Leave empty for a single robot. Use values like robot1, robot2 for multi-robot use.
ROSBOT_NAMESPACE=

# Default launch behavior. You can override these per command with flags.
ROSBOT_START_CAMERA=false
ROSBOT_START_LIDAR=true
ROSBOT_START_JOY=false

# ROS networking defaults.
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# Set true to stream launch output in the terminal by default.
ROSBOT_VERBOSE=false

# Runtime files for the public CLI. Launch logs are stored under this directory.
ROSBOT_RUN_DIR=$HOME/.rosbot

# Default refresh interval for ./rosbot monitor.
ROSBOT_MONITOR_INTERVAL=2

# Serial device used by the RPLIDAR motor stop holder.
ROSBOT_LIDAR_PORT=/dev/rplidar

# Battery status and low-battery safety.
ROSBOT_BATTERY_TOPIC=battery
ROSBOT_BATTERY_SAFETY=true
ROSBOT_BATTERY_WARN_PERCENT=20
ROSBOT_BATTERY_STOP_PERCENT=10
ROSBOT_BATTERY_STOP_DELAY=60
ROSBOT_BATTERY_STOP_TIMEOUT=20
ROSBOT_BATTERY_TREND_WINDOW=120
ROSBOT_BATTERY_TREND_MIN_DV=0.03

# Keep true so normal teleop_twist_keyboard Twist commands work with the stamped controller.
ROSBOT_TWIST_BRIDGE=true
ROSBOT_TWIST_BRIDGE_IN=cmd_vel
ROSBOT_TWIST_BRIDGE_OUT=cmd_vel_stamped
